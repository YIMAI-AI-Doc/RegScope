generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  ARTICLE
  POLICY
  NEWS
  GUIDANCE
  ALERT
}

enum FollowTargetType {
  COUNTRY
  SOURCE
  TOPIC
}

enum FeedFormat {
  AUTO
  RSS
  ATOM
  JSON
}

enum DiscussionStatus {
  OPEN
  IN_REVIEW
  PROVISIONAL_CONCLUSION
  CONTROVERSIAL
  CLOSED
}

enum EvidenceLabel {
  OFFICIAL
  ANALYSIS
  EXPERIENCE
  UNVERIFIED
}

enum PetTierSlug {
  FANZAI
  MENGLING
  ZHENCHONG
  LINGZUN
  SHENSHOU
}

enum PetGrowthStage {
  BABY
  GROWING
  MATURE
}

enum PetEventType {
  DAILY_QUESTION
  COMMENT
  ARTICLE
  DISCUSSION_POST
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  role         String        @default("USER")
  avatarUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  follows      Follow[]
  discussions  Discussion[]
  answers      Answer[]
  answerVotes  AnswerVote[]
  discussionViews DiscussionView[]
  conclusions  DiscussionConclusion[] @relation("ConclusionEditedBy")
  contentFavorites    ContentFavorite[]
  discussionFavorites DiscussionFavorite[]
  dailyQuizResponses  DailyQuizResponse[]
  petProfile          UserPetProfile?
  petEvents           UserPetEvent[]
}

model PetTier {
  id        String       @id @default(cuid())
  slug      PetTierSlug  @unique
  name      String
  sortOrder Int          @unique
  species   PetSpecies[]
  profiles  UserPetProfile[]
}

model PetSpecies {
  id                String           @id @default(cuid())
  slug              String           @unique
  name              String
  tierId            String
  tier              PetTier          @relation(fields: [tierId], references: [id], onDelete: Cascade)
  motionPreset      String
  visualStyle       String
  title             String
  traitKeywords     String[]
  growthStageConfig Json
  profiles          UserPetProfile[]
}

model UserPetProfile {
  id                String          @id @default(cuid())
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentTierId     String
  currentTier       PetTier         @relation(fields: [currentTierId], references: [id], onDelete: Cascade)
  currentSpeciesId  String
  currentSpecies    PetSpecies      @relation(fields: [currentSpeciesId], references: [id], onDelete: Cascade)
  currentPoints     Int             @default(0)
  currentStage      PetGrowthStage  @default(BABY)
  totalPointsEarned Int             @default(0)
  lastUpgradeAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  events            UserPetEvent[]

  @@index([currentTierId])
  @@index([currentSpeciesId])
}

model UserPetEvent {
  id         String         @id @default(cuid())
  userPetId  String
  userPet    UserPetProfile @relation(fields: [userPetId], references: [id], onDelete: Cascade)
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType  PetEventType
  points     Int
  sourceId   String?
  sourceType String?
  createdAt  DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@unique([userId, eventType, sourceId, sourceType])
}

model Country {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  region      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sources     Source[]
  contents    ContentItem[]
  follows     Follow[]
  discussions Discussion[]
}

model Source {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  websiteUrl  String?
  feedUrl     String?
  feedFormat  FeedFormat @default(AUTO)
  countryId   String?
  country     Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  isOfficial  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contents    ContentItem[]
  follows     Follow[]
}

model Topic {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  parentId    String?
  parent      Topic?    @relation("TopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Topic[]   @relation("TopicTree")
  level       Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contents    ContentItem[]
  discussions Discussion[]
  follows     Follow[]
}

model ContentItem {
  id             String      @id @default(cuid())
  slug           String      @unique
  title          String
  summary        String
  body           String?
  canonicalUrl   String      @unique
  contentType    ContentType
  publishedAt    DateTime
  sourceId       String
  source         Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  countryId      String?
  country        Country?    @relation(fields: [countryId], references: [id], onDelete: SetNull)
  primaryTopicId String?
  primaryTopic   Topic?      @relation(fields: [primaryTopicId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  favorites      ContentFavorite[]
}

model Follow {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType     FollowTargetType
  countryId      String?
  country        Country?         @relation(fields: [countryId], references: [id], onDelete: Cascade)
  sourceId       String?
  source         Source?          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  topicId        String?
  topic          Topic?           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([userId, targetType])
  @@unique([userId, targetType, countryId, sourceId, topicId])
}

model Discussion {
  id           String                 @id @default(cuid())
  slug         String                 @unique
  title        String
  summary      String
  status       DiscussionStatus       @default(OPEN)
  countryId    String?
  country      Country?               @relation(fields: [countryId], references: [id], onDelete: SetNull)
  topicId      String?
  topic        Topic?                 @relation(fields: [topicId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  conclusion   DiscussionConclusion?
  evidence     DiscussionEvidence[]
  answers      Answer[]
  views        DiscussionView[]
  favorites    DiscussionFavorite[]
}

model DiscussionConclusion {
  id            String     @id @default(cuid())
  discussionId  String     @unique
  discussion    Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  summary       String
  evidenceNote  String?
  updatedById   String?
  updatedBy     User?      @relation("ConclusionEditedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt     DateTime   @updatedAt
  createdAt     DateTime   @default(now())
}

model DiscussionEvidence {
  id            String           @id @default(cuid())
  discussionId  String
  discussion    Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  title         String
  url           String?
  sourceLabel   EvidenceLabel
  note          String?
  createdAt     DateTime         @default(now())

  @@unique([discussionId, title])
}

model Answer {
  id            String           @id @default(cuid())
  discussionId  String
  discussion    Discussion       @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId      String
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body          String
  evidenceLabel EvidenceLabel    @default(UNVERIFIED)
  isAccepted    Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  votes         AnswerVote[]

  @@unique([discussionId, authorId, body])
}

model DiscussionView {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId  String
  discussion    Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  viewCount     Int         @default(1)
  createdAt     DateTime    @default(now())
  lastViewedAt  DateTime    @updatedAt

  @@unique([userId, discussionId])
  @@index([userId, lastViewedAt])
  @@index([discussionId, lastViewedAt])
}

model AnswerVote {
  id         String    @id @default(cuid())
  answerId   String
  answer     Answer    @relation(fields: [answerId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  value      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([answerId, userId])
  @@index([userId, updatedAt])
}

model ContentFavorite {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId  String
  content    ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@unique([userId, contentId])
  @@index([userId, createdAt])
  @@index([contentId, createdAt])
}

model DiscussionFavorite {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId  String
  discussion    Discussion  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, discussionId])
  @@index([userId, createdAt])
  @@index([discussionId, createdAt])
}

model QuizQuestion {
  id              String                @id @default(cuid())
  sequence        Int                   @unique
  sourceNumber    Int                   @unique
  typeLabel       String
  difficultyLabel String?
  prompt          String
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  correctOption   String
  legalBasis      String
  explanation     String
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  assignments     DailyQuizAssignment[]
}

model DailyQuizAssignment {
  id          String              @id @default(cuid())
  dateKey     String              @unique
  questionId  String
  question    QuizQuestion        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sequence    Int
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  responses   DailyQuizResponse[]

  @@index([sequence])
}

model DailyQuizResponse {
  id             String               @id @default(cuid())
  assignmentId   String
  assignment     DailyQuizAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedOption String
  isCorrect      Boolean
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([assignmentId, userId])
  @@index([userId, createdAt])
  @@index([assignmentId, createdAt])
}
